generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Định nghĩa các quyền trong hệ thống
enum UserRole {
  USER          // Người dùng bình thường
  TECHNICIAN    // Thợ sửa chữa
  ADMIN         // Quản trị viên
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id              Int           @id @default(autoincrement())
  
  // Thông tin đăng nhập chính
  phoneNumber     String        @unique      // SĐT là bắt buộc và duy nhất
  password        String                     // Mật khẩu (sẽ băm bằng bcrypt)
  
  // Thông tin cá nhân
  fullName        String?
  gender          Gender
  email           String?       @unique
  avatarUrl       String?                    // Ảnh đại diện
  address         String?                    // Địa chỉ (VD: Thủ Đức, TP.HCM)
  
  // Quản lý trạng thái & Phân quyền
  role            UserRole      @default(USER)
  isVerified      Boolean       @default(false) // Đã xác thực OTP chưa?
  isActive        Boolean       @default(true)  // Có đang bị khóa không?
  
  // Lưu vết thời gian
  lastLogin       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // 2. Mối quan hệ: Một User có nhiều phiên Chat và Thiết bị
  chatSessions    ChatSession[]
  devices         Device[]

  @@map("users") // Đặt tên bảng trong Postgres là 'users' cho chuẩn
}

// 3. Bảng lưu trữ lịch sử chẩn đoán của AI
model ChatSession {
  id              Int      @id @default(autoincrement())
  deviceType      String?  // Loại máy: Máy giặt, Tủ lạnh...
  symptom         String?  // Triệu chứng: Không lạnh, kêu to...
  aiSummary       String?  @db.Text // Tóm tắt chẩn đoán của AI
  isDangerous     Boolean  @default(false) // Có phải mức Đỏ không?
  
  // Khóa ngoại liên kết với User
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Khóa ngoại liên kết với Device
  deviceId        Int?
  device          Device?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("chat_sessions")
}

// 4. Bảng quản lý kho thiết bị của User (My Appliances)
model Device {
  id                     Int       @id @default(autoincrement())
  category               String    // Loại: Tủ lạnh, Máy lạnh...
  brandName              String    // Hãng: Panasonic...
  modelCode              String?   // Mã máy
  location               String?   // Vị trí (Phòng khách, Bếp...)
  purchaseDate           DateTime? // Ngày mua
  warrantyMonths         Int?      // Số tháng bảo hành
  maintenanceCycleMonths Int?      // Chu kỳ bảo trì (tháng)
  nextMaintenanceDate    DateTime? // Ngày bảo trì tiếp theo
  
  userId                 Int
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  chatSessions           ChatSession[]
  
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  
  @@map("devices")
}